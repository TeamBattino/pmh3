{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": [
        "AUTH_SECRET",
        "MONGODB_CONNECTION_STRING",
        "MONGODB_DB_NAME",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_SECRET",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_REGION",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_PUBLIC_URL_BASE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test:unit": {
      "outputs": []
    },
    "test:integration": {
      "outputs": [],
      "cache": false,
      "passThroughEnv": ["DOCKER_HOST", "TESTCONTAINERS_RYUK_DISABLED"]
    },
    "test:e2e": {
      "outputs": [],
      "cache": false,
      "passThroughEnv": ["DOCKER_HOST"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "type-check": {}
  }
}
