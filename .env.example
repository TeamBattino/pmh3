MONGODB_CONNECTION_STRING=mongodb://root:example@localhost:27017
MONGODB_DB_NAME=pfadimh-db

# Admin app auth (points to auth service)
AUTH_SECRET=some-secret
AUTH_TRUST_HOST=http://localhost:3001
AUTH_OIDC_ISSUER=http://localhost:3002
AUTH_OIDC_CLIENT_ID=pfadimh-admin
AUTH_OIDC_CLIENT_SECRET=dev-secret

# Auth service
AUTH_PORT=3002
AUTH_ISSUER_URL=http://localhost:3002

# MiData upstream (mock-oidc in dev, db.scout.ch in prod)
MIDATA_AUTHORIZE_URL=http://localhost:9000/default/authorize
MIDATA_TOKEN_URL=http://localhost:9000/default/token
MIDATA_USERINFO_URL=http://localhost:9000/default/userinfo
MIDATA_CLIENT_ID=pfadimh-sso
MIDATA_CLIENT_SECRET=dev-secret

# S3-compatible storage (Railway bucket in prod, MinIO locally)
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=pfadimh-files
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL_BASE=http://localhost:9100/pfadimh-files
