# ─── Shared ──────────────────────────────────────────────────────────
# Used by all three services (admin, site, auth)
MONGODB_CONNECTION_STRING=mongodb://root:example@localhost:27017
MONGODB_DB_NAME=pfadimh-db

# ─── Admin app ───────────────────────────────────────────────────────
# Auth.js / OIDC client (points to the auth service)
AUTH_SECRET=some-secret
AUTH_OIDC_ISSUER=http://localhost:3002
AUTH_OIDC_CLIENT_ID=pfadimh-admin
AUTH_OIDC_CLIENT_SECRET=dev-secret
# Prod only — set to `true` so Auth.js trusts the Railway proxy's Host header.
# (In dev, Auth.js picks the host up from the request automatically.)
AUTH_TRUST_HOST=
# Optional override — pin the public URL explicitly instead of relying on
# AUTH_TRUST_HOST. Leave empty for local dev.
AUTH_URL=

# ─── Auth service ────────────────────────────────────────────────────
AUTH_PORT=3002
# Public URL of this auth service. In dev matches AUTH_OIDC_ISSUER above.
# In prod, set to the auth service's Railway URL.
AUTH_ISSUER_URL=http://localhost:3002
# Optional: PEM-encoded RSA/EC key for signing JWTs. If unset, a key is
# generated at startup (fine for single-instance; set explicitly for multi-
# replica deployments so all replicas sign with the same key).
AUTH_SIGNING_KEY_PEM=

# ─── Admin client (managed by the auth service) ──────────────────────
# These drive the syncAdminClient() upsert at auth-service boot. Changing
# them + restarting the auth service is the recovery path if the admin's
# OIDC callback URL or secret ever need to change.
#
# ADMIN_URL — public URL of the admin service. Appended as a valid redirect
# URI alongside the localhost/docker defaults. Prod example:
#   https://admin.pfadimh.ch
ADMIN_URL=
# ADMIN_CLIENT_SECRET — raw secret (not hashed). Must match the admin's
# AUTH_OIDC_CLIENT_SECRET. Defaults to "dev-secret" when empty.
ADMIN_CLIENT_SECRET=

# ─── MiData upstream (mock-oidc in dev, db.scout.ch in prod) ─────────
MIDATA_AUTHORIZE_URL=http://localhost:9000/default/authorize
MIDATA_TOKEN_URL=http://localhost:9000/default/token
MIDATA_USERINFO_URL=http://localhost:9000/default/userinfo
MIDATA_CLIENT_ID=pfadimh-sso
MIDATA_CLIENT_SECRET=dev-secret

# ─── S3-compatible storage (admin only) ──────────────────────────────
# The site never talks to S3. Reads go through presigned GET URLs minted
# by the admin and embedded in SSR'd HTML (7-day TTL).
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=pfadimh-files
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
