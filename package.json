{
  "name": "pfadipuck",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=@pfadipuck/admin",
    "dev:site": "turbo dev --filter=@pfadipuck/site",
    "build": "turbo build",
    "build:admin": "turbo build --filter=@pfadipuck/admin",
    "build:site": "turbo build --filter=@pfadipuck/site",
    "lint": "turbo lint",
    "test": "turbo test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "turbo type-check"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.1.11",
    "@storybook/nextjs-vite": "^10.1.11",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.13",
    "eslint-plugin-storybook": "^0.12.0",
    "playwright": "^1.57.0",
    "storybook": "^10.1.11",
    "turbo": "^2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17",
    "vitest-browser-react": "^2.0.2"
  },
  "packageManager": "bun@1.3.11"
}
